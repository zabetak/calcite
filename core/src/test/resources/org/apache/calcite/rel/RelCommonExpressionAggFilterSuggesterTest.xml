  <TestCase name="testPattern1">
    <Resource name="suggestion_0">
      <![CDATA[LogicalAggregate(group=[{}], EXPR$0=[COUNT($0)], EXPR$0=[COUNT($1)])
  LogicalProject($f0=[CASE(SEARCH($2, Sarg[[1..20]]), 1, null:INTEGER)], $f1=[CASE(SEARCH($2, Sarg[[21..40]]), 1, null:INTEGER)])
    LogicalTableScan(table=[[EMP]])
]]>
    </Resource>
    <Resource name="suggestion_1">
      <![CDATA[LogicalAggregate(group=[{}], EXPR$0=[COUNT()])
  LogicalFilter(condition=[SEARCH($2, Sarg[[1..20]])])
    LogicalTableScan(table=[[EMP]])
]]>
    </Resource>
    <Resource name="suggestion_2">
      <![CDATA[LogicalAggregate(group=[{}], EXPR$0=[COUNT()])
  LogicalFilter(condition=[SEARCH($2, Sarg[[21..40]])])
    LogicalTableScan(table=[[EMP]])
]]>
    </Resource>
    <Resource name="suggestion_3">
      <![CDATA[LogicalFilter(condition=[SEARCH($2, Sarg[[1..20], [21..40]])])
  LogicalTableScan(table=[[EMP]])
]]>
    </Resource>
  </TestCase>
